{
  "manifest_version": 3,
  "name": "ikipedia",
  "version": "1.0.0",
  "description": "wikipediaにのみ作用する拡張",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "*://*.wikipedia.org/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.wikipedia.org/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
